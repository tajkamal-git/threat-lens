# ─────────────────────────────────────────────────────────────────────────────
# ThreatLens — Environment Variables
# Copy this file to .env.local and populate with your values.
# NEVER commit .env.local or any file containing real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Splunk Enterprise REST API (Phase 1) ─────────────────────────────────────
# Base URL of your Splunk Enterprise management port (always 8089).
# IMPORTANT: If Splunk runs on localhost/a home VM, Vercel's cloud functions
# cannot reach it directly — tunnel it first (ngrok or Cloudflare Tunnel) and
# put the public tunnel URL here instead of localhost.
SPLUNK_BASE_URL=https://localhost:8089

# Authentication — use ONE of the two methods below.
#
# Method 1: Username + Password (use this on a Free license — the Tokens
# feature under Settings → Tokens requires a licensed/trial Enterprise install
# and is not available on Free).
SPLUNK_USERNAME=
SPLUNK_PASSWORD=
#
# Method 2: Bearer token (only if your license supports Settings → Tokens).
# Leave SPLUNK_TOKEN empty to use username/password instead — the backend
# automatically falls back to Basic Auth when no token is set.
SPLUNK_TOKEN=

# Index and sourcetype to search — confirmed for this project:
SPLUNK_INDEX=main
SPLUNK_SOURCETYPE=WinEventLog:Security

# Splunk's default cert is self-signed — set to "false" for local/lab Splunk.
# Only set "true" when Splunk has a real CA-issued certificate.
SPLUNK_VERIFY_SSL=false

# ── AI Investigation Assistant (Phase 8) ─────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Platform ─────────────────────────────────────────────────────────────────
# Secret key for JWT signing and session encryption (generate with: openssl rand -hex 32)
THREATLENS_SECRET_KEY=

# ── Database (Phase 9 — Case Management) ─────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/threatlens

# ── Cache (Phase 2 — Real-time Streaming) ────────────────────────────────────
# REDIS_URL=redis://localhost:6379
