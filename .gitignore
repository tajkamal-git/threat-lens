# ──────────────────────────────────────────────────────────────────────────────
# ThreatLens — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules

# Build outputs
dist
dist-ssr
.output
.vinxi
.tanstack/**
.nitro

# Local environment — NEVER commit secrets
.env
.env.local
.env.*.local
.dev.vars

# Wrangler / Cloudflare
.wrangler/

# Editor
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
